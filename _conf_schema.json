{
  "forward_target_qq": {
    "description": "头衔申请转发目标QQ",
    "hint": "接收头衔申请通知的群主QQ号，不填则无法转发申请",
    "type": "string",
    "default": "",
    "obvious_hint": true
  },
  "command_prefix": {
    "description": "指令前缀",
    "hint": "触发插件指令的前缀字符，如 / 或 !，留空表示不需要前缀",
    "type": "string",
    "default": ""
  },
  "rate_limit": {
    "description": "频率限制配置",
    "hint": "防止用户频繁申请头衔的防骚扰机制",
    "type": "object",
    "items": {
      "min_interval": {
        "description": "最小申请间隔（分钟）",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 60,
          "step": 1
        },
        "default": 5
      },
      "daily_limit": {
        "description": "每日申请次数上限",
        "type": "int",
        "slider": {
          "min": 1,
          "max": 20,
          "step": 1
        },
        "default": 3
      }
    }
  },
  "super_admin": {
    "description": "超级管理员QQ号",
    "hint": "拥有插件管理权限的QQ号，通常与 AstrBot 管理员一致，不填则只允许 AstrBot 管理员操作",
    "type": "string",
    "default": ""
  },
  "auto_approve": {
    "description": "自动批准头衔申请",
    "hint": "开启后，头衔申请将自动批准而不需要群主确认",
    "type": "bool",
    "default": false
  }
}
